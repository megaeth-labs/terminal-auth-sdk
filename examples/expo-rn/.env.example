# Privy credentials — get these from https://dashboard.privy.io
# after creating an app. Both are required.
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Terminal backend configuration.
#
# - EXPO_PUBLIC_TERMINAL_CLIENT_ID: the Terminal client ID the backend
#   team has allowlisted for this example's redirect URI
#   (com.megaethlabs.terminalauthsdk.example://terminal-auth).
# - EXPO_PUBLIC_TERMINAL_API_URL / EXPO_PUBLIC_TERMINAL_ORIGIN are
#   optional — leave them blank to use the SDK's built-in staging
#   defaults (terminal-backend-git-staging-mega-eth.vercel.app +
#   staging-terminal.megaeth.com).
EXPO_PUBLIC_TERMINAL_CLIENT_ID=test
# EXPO_PUBLIC_TERMINAL_API_URL=
# EXPO_PUBLIC_TERMINAL_ORIGIN=
